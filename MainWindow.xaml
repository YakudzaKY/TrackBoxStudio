<Window x:Class="TrackBoxStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:TrackBoxStudio.Models"
        mc:Ignorable="d"
        Title="TrackBoxStudio"
        Height="980"
        Width="1560"
        MinHeight="840"
        MinWidth="1380"
        Background="#0F1118">
    <Window.Resources>
        <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="#2B3040" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#202433" />
            <Setter Property="BorderBrush" Value="#31384C" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#0F1118" />
            <Setter Property="BorderBrush" Value="#31384C" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#0F1118" />
            <Setter Property="BorderBrush" Value="#31384C" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#171923" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#10131C" />
            <Setter Property="BorderBrush" Value="#31384C" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#171923" Padding="16" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Open File" Click="OpenInput_Click" Background="#38BDF8" Foreground="#06111A" Margin="0,0,10,0" />
                    <Button Content="Open Project" Click="OpenProject_Click" Margin="0,0,10,0" />
                    <Button Content="Save Project" Click="SaveProject_Click" IsEnabled="{Binding CanSaveProject}" Margin="0,0,10,0" />
                    <Button Content="Choose Output" Click="ChooseOutput_Click" Margin="0,0,10,0" />
                    <Button Content="Inpaint Tuning" Click="OpenInpaintTuning_Click" Margin="0,0,10,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="16,0">
                    <TextBlock Text="Project" Foreground="#8B93A7" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CurrentProjectDisplay}" Foreground="White" FontSize="14" TextTrimming="CharacterEllipsis" Width="260" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="16,0">
                    <TextBlock Text="Input" Foreground="#8B93A7" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding InputPath}" Foreground="White" FontSize="14" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,16,0">
                    <TextBlock Text="Output" Foreground="#8B93A7" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding OutputPath}" Foreground="White" FontSize="14" TextTrimming="CharacterEllipsis" Width="320" />
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                    <TextBlock Text="Inpaint Strategy" Foreground="#8B93A7" FontSize="12" FontWeight="SemiBold" />
                    <ComboBox Width="180"
                              ItemsSource="{Binding InpaintStrategyOptions}"
                              SelectedItem="{Binding SelectedInpaintStrategy, Mode=TwoWay}" />
                </StackPanel>

                <Button Grid.Column="5" Content="Start Processing" Click="Process_Click" IsEnabled="{Binding CanProcess}" Background="#4ADE80" Foreground="#06140C" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" x:Name="RegistryPanel" Background="#171923" Padding="16" Margin="0,0,14,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Watermark Registry" Foreground="White" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="Stored next to the app in Data\watermark-registry.json"
                                   Foreground="#8B93A7"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                        <Button Content="New Watermark" Click="AddWatermark_Click" Margin="0,0,0,8" />
                        <Button Content="Rename Watermark" Click="RenameWatermark_Click" Margin="0,0,0,8" />
                        <Button Content="Delete Watermark" Click="DeleteWatermark_Click" Background="#34131D" BorderBrush="#5C2230" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding WatermarkRegistry}"
                             SelectedItem="{Binding SelectedWatermarkDefinition, Mode=TwoWay}"
                             Margin="0,14,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:WatermarkDefinition}">
                                <Border Background="#111520" Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Id}"
                                                   Foreground="#717A90"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          Background="#2B3040" />

            <Border Grid.Column="2" x:Name="EditorPanel" Background="#171923" Padding="16" Margin="14,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Frame Preview" Foreground="White" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedTrackStatus}" Foreground="#8B93A7" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="1" Background="#080B11" Margin="0,14,0,0" Padding="10">
                        <Grid>
                            <TextBlock Text="Open a video, pick a track, and draw a box with the mouse."
                                       Foreground="#6E7486"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMediaLoaded}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Viewbox Stretch="Uniform">
                                    <Grid Width="{Binding FrameCanvasWidth}" Height="{Binding FrameCanvasHeight}">
                                        <Image Source="{Binding CurrentFrameImage}" Stretch="Fill" />
                                        <ItemsControl ItemsSource="{Binding OverlayBoxes}" IsHitTestVisible="False">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:OverlayBox}">
                                                    <Grid>
                                                        <Rectangle Width="{Binding Width}"
                                                                   Height="{Binding Height}"
                                                                   Stroke="{Binding Stroke}"
                                                                   Fill="{Binding Fill}"
                                                                   StrokeThickness="{Binding StrokeThickness}" />
                                                        <Border Background="{Binding LabelBackground}" Padding="5,2" Margin="2">
                                                            <TextBlock Text="{Binding Label}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Canvas x:Name="OverlayInputCanvas"
                                                Background="Transparent"
                                                MouseLeftButtonDown="OverlayInputCanvas_MouseLeftButtonDown"
                                                MouseMove="OverlayInputCanvas_MouseMove"
                                                MouseLeftButtonUp="OverlayInputCanvas_MouseLeftButtonUp"
                                                MouseLeave="OverlayInputCanvas_MouseLeave" />
                                    </Grid>
                                </Viewbox>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Background="#10141F" Margin="0,14,0,0" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Timeline" Foreground="White" FontWeight="SemiBold" />
                                <Slider x:Name="FrameSlider"
                                        Minimum="0"
                                        Maximum="{Binding SliderMaximum}"
                                        Value="{Binding CurrentFrameIndex, Mode=TwoWay}"
                                        ValueChanged="FrameSlider_ValueChanged"
                                        Margin="0,12,0,0"
                                        IsEnabled="{Binding IsMediaLoaded}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                <TextBlock Text="{Binding CurrentFrameDisplay}" Foreground="#D9E1F2" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CurrentTimeDisplay}" Foreground="#8B93A7" Margin="0,6,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" Background="#10141F" Margin="0,14,0,0" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Draft Box" Foreground="White" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding DraftBoxSummary}" Foreground="#8B93A7" Margin="0,6,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                                <Button Content="Save Box Here" Click="SaveBoxHere_Click" IsEnabled="{Binding CanSaveCurrentBox}" Background="#4ADE80" Foreground="#06140C" Margin="0,0,8,0" />
                                <Button Content="{Binding ToggleTrackHereLabel}" Click="DisableHere_Click" IsEnabled="{Binding CanToggleTrackStateHere}" Margin="0,0,8,0" />
                                <Button Content="Remove Keyframe" Click="RemoveKeyframeHere_Click" IsEnabled="{Binding CanRemoveKeyframeHere}" Background="#34131D" BorderBrush="#5C2230" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            <GridSplitter Grid.Column="3"
                          Width="8"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          Background="#2B3040" />

            <Border Grid.Column="4" x:Name="TracksPanel" Background="#171923" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Timeline Tracks" Foreground="White" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="Each track references a named watermark from the registry."
                                       Foreground="#8B93A7"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Content="Add Track" DockPanel.Dock="Right" Click="AddTrack_Click" IsEnabled="{Binding IsMediaLoaded}" Background="#4ADE80" Foreground="#06140C" />
                    </DockPanel>

                    <Border Grid.Row="1" Background="#10141F" Padding="12" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedTrackStatus}" Foreground="#D9E1F2" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedTrackKeyframeStatus}" Foreground="#8B93A7" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Tracks}"
                             SelectedItem="{Binding SelectedTrack, Mode=TwoWay}"
                             Margin="0,14,0,0"
                             MinHeight="220">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:TimelineTrack}">
                                <Border Background="#111520" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <DockPanel>
                                            <Ellipse Width="12" Height="12" Fill="{Binding TrackBrush}" Margin="0,3,10,0" DockPanel.Dock="Left" />
                                            <Button Content="Remove" DockPanel.Dock="Right" Tag="{Binding}" Click="RemoveTrack_Click" Padding="8,4" Background="#34131D" BorderBrush="#5C2230" />
                                            <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                        <DockPanel Margin="0,10,0,0">
                                            <ComboBox ItemsSource="{Binding DataContext.WatermarkRegistry, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      DisplayMemberPath="Name"
                                                      SelectedValuePath="Id"
                                                      SelectedValue="{Binding WatermarkId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectionChanged="TrackWatermarkSelectionChanged" />
                                            <Button Content="New" DockPanel.Dock="Right" Margin="8,0,0,0" Padding="10,6" Tag="{Binding}" Click="CreateWatermarkForTrack_Click" />
                                        </DockPanel>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                                            <ItemsControl ItemsSource="{Binding Segments}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:TrackSegmentPreview}">
                                                        <Border Background="{Binding Fill}"
                                                                BorderBrush="{Binding Border}"
                                                                BorderThickness="1"
                                                                Padding="8,4"
                                                                Margin="0,0,6,0"
                                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                ContextMenuOpening="TrackSegmentBorder_ContextMenuOpening">
                                                            <TextBlock Text="{Binding Label}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <GridSplitter Grid.Row="3"
                                  Height="8"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  ResizeDirection="Rows"
                                  Background="#2B3040" />

                    <Border Grid.Row="4" Background="#10141F" Padding="14" Margin="0,14,0,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Selected Track Keyframes" Foreground="White" FontWeight="SemiBold" />
                                <TextBlock Text="Jump to a frame to validate transitions or remove stale keyframes."
                                           Foreground="#8B93A7"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ListBox ItemsSource="{Binding SelectedTrack.Keyframes}" Margin="0,14,0,0" MinHeight="180">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:BoxKeyframe}">
                                        <Border Background="#0D1119" Padding="10" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Frame}" Foreground="White" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding StateLabel}" Foreground="#8B93A7" Margin="0,4,0,0" />
                                                    <TextBlock Text="{Binding BoxLabel}" Foreground="#6E7486" Margin="0,4,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                                                    <Button Content="Jump" Tag="{Binding}" Click="JumpToKeyframe_Click" Padding="8,4" Margin="0,0,8,0" />
                                                    <Button Content="Delete" Tag="{Binding}" Click="DeleteKeyframe_Click" Padding="8,4" Background="#34131D" BorderBrush="#5C2230" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="5" Background="#10141F" Padding="14" Margin="0,14,0,0">
                        <TextBlock Text="{Binding RegistryLocation}" Foreground="#6E7486" TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#171923" Padding="14" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontWeight="SemiBold" />
                    <TextBlock Text="Deepfake laundering is prohibited. TrackBoxStudio is intended for entertainment, parody, and other lawful creative content only."
                               Foreground="#8B93A7" Margin="0,6,0,0" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <ProgressBar Height="18"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressValue, Mode=OneWay}" />
                    <TextBlock Text="{Binding ProgressDisplay}" Foreground="#8B93A7" Margin="0,6,0,0" HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
