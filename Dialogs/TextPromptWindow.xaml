<Window x:Class="TrackBoxStudio.Dialogs.TextPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrackBoxStudio"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="#171923">
    <Border Padding="20">
        <StackPanel Width="360">
            <TextBlock x:Name="PromptTextBlock"
                       Foreground="White"
                       FontSize="15"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />
            <TextBox x:Name="InputTextBox"
                     Margin="0,12,0,0"
                     MinWidth="320"
                     Padding="10"
                     Background="#0F1118"
                     Foreground="White"
                     BorderBrush="#3A3F51" />
            <DockPanel Margin="0,16,0,0">
                <Button Content="Cancel"
                        Width="90"
                        Margin="0,0,10,0"
                        Click="Cancel_Click" />
                <Button Content="Save"
                        Width="90"
                        DockPanel.Dock="Right"
                        IsDefault="True"
                        Click="Save_Click" />
            </DockPanel>
        </StackPanel>
    </Border>
</Window>
