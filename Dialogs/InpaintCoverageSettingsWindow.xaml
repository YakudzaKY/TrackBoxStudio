<Window x:Class="TrackBoxStudio.Dialogs.InpaintCoverageSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Inpaint Tuning"
        Width="1520"
        Height="980"
        MinWidth="1320"
        MinHeight="860"
        WindowStartupLocation="CenterOwner"
        Background="#0F1118">
    <Window.Resources>
        <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="#2B3040" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#202433" />
            <Setter Property="BorderBrush" Value="#31384C" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#0F1118" />
            <Setter Property="BorderBrush" Value="#31384C" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#0F1118" />
            <Setter Property="BorderBrush" Value="#31384C" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#171923" Padding="16" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Stable Mask Tuning"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold" />
                    <TextBlock Text="Edit the stable-mask JSON that the Python runner uses, then preview the same settings on the problem sample."
                               Foreground="#8B93A7"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1" Background="#10141F" Padding="14" MinWidth="320">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#D9E1F2"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#171923" Padding="16" Margin="0,0,14,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Stable Mask Config"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock Text="Use decimal points, for example 0.48. Integer knobs expect whole numbers."
                                   Foreground="#8B93A7"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0">
                        <Button Content="Reset To Default"
                                Width="150"
                                Margin="0,0,10,0"
                                Click="ResetToDefault_Click" />
                        <Button Content="Save"
                                Width="110"
                                Margin="0,0,10,0"
                                Click="Save_Click"
                                Background="#38BDF8"
                                Foreground="#06111A" />
                        <Button Content="Close"
                                Width="110"
                                Click="Close_Click" />
                    </StackPanel>

                    <ScrollViewer Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CoverageSettings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#10141F" Padding="12" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding GroupName}"
                                                       Foreground="#8B93A7"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                            <Grid Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="White"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                                <Button Grid.Column="1"
                                                        Content="Reset"
                                                        MinWidth="76"
                                                        Margin="12,0,0,0"
                                                        Padding="10,4"
                                                        VerticalAlignment="Center"
                                                        IsEnabled="{Binding CanResetToDefault}"
                                                        Click="ResetEntryToDefault_Click" />
                                            </Grid>
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="#AAB3C5"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding DefaultValueText, StringFormat=Default: {0}}"
                                                       Foreground="#6E7486"
                                                       Margin="0,6,0,0"
                                                       FontSize="11" />
                                            <TextBox Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#171923" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Reference Crops"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock Text="Before Try these are the original box crops. After Try the stable mask is tinted over them so you can inspect coverage."
                                   Foreground="#8B93A7"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap" />

                        <ItemsControl ItemsSource="{Binding ReferenceSamples}" Margin="0,14,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#10141F" Padding="10" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold" />
                                            <Border Background="#080B11" Margin="0,10,0,0" Padding="6">
                                                <Image Source="{Binding Image}"
                                                       Stretch="Uniform"
                                                       Height="132" />
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="#171923" Padding="16" Margin="0,14,0,14">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="Preview"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="Bold" />
                            <TextBlock Text="Try saves the current JSON, renders the stable mask as an overlay on the sample boxes, then runs inpaint on full frames and crops the result back to your box."
                                       Foreground="#8B93A7"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Strategy"
                                           Foreground="#8B93A7"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                                <ComboBox Width="180"
                                          ItemsSource="{Binding InpaintStrategyOptions}"
                                          SelectedItem="{Binding SelectedInpaintStrategy, Mode=TwoWay}" />
                            </StackPanel>
                            <Button Content="Try"
                                    Width="120"
                                    Background="#4ADE80"
                                    Foreground="#06140C"
                                    Click="Try_Click" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2" Background="#171923" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Try Results"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock Text="Bottom row shows the processed crop for each sample."
                                   Foreground="#8B93A7"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap" />

                        <ItemsControl ItemsSource="{Binding PreviewSamples}" Margin="0,14,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#10141F" Padding="10" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold" />
                                            <Border Background="#080B11" Margin="0,10,0,0" Padding="6" Height="168">
                                                <Grid>
                                                    <Image Source="{Binding Image}"
                                                           Stretch="Uniform" />
                                                    <TextBlock Text="Run Try to refresh this preview."
                                                               Foreground="#6E7486"
                                                               FontSize="14"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Image}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
